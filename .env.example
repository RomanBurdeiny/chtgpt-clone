# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LLM: at least one provider (priority: NVIDIA → DeepSeek → OpenAI)
#
# NVIDIA NIM / API (nvapi-… key from build.nvidia.com)
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
# NVIDIA_CHAT_THINKING=true  # optional; can delay first streamed token
#
# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
# Base URL must end with /v1 (matches SDK path …/v1/chat/completions)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# or for reasoning mode: DEEPSEEK_MODEL=deepseek-reasoner
#
# Or OpenAI instead of DeepSeek:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Long replies / history: avoid blowing the model context window (optional)
# LLM_HISTORY_MESSAGE_LIMIT=48
# LLM_HISTORY_MAX_CHARS=100000
# NVIDIA_MAX_OUTPUT_TOKENS=16384

# Vercel: max serverless seconds for POST .../messages stream (Hobby max 300; omit or 300 on Hobby)
# MESSAGES_MAX_DURATION=300
